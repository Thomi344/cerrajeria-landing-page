---
// ---- Pagina de diseño de la pagina 404 ----
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Cerrajería Wally" description="Lo sentimos, la página que buscas no existe. Contactanos para urgencias de cerrajería las 24 horas.">
    <section class="min-h-[70vh] flex items-center justify-center bg-fondo-base px-4 py-20">
        <div class="max-w-2xl w-full text-center">
            <div class="relative mb-8">
                <h1 class="text-9xl font-black text-slate-800 animate-pulse">404</h1>
                <p class="absolute inset-0 flex items-center justify-center text-4xl md:text-5xl font-bold text-white uppercase tracking-tighter">
                ¡Ups!
                </p>
            </div>

            <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
                Parece que esta llave no abre ninguna puerta
            </h2>
            
            <p class="text-slate-400 text-lg mb-12 max-w-md mx-auto">
                La página que estás buscando no existe o fue movida. Pero no te preocupes, nosotros sí estamos disponibles para ayudarte.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/" class="w-full sm:w-auto bg-slate-800 hover:bg-slate-700 text-white font-bold py-4 px-8 rounded-xl transition-all border border-borde">
                Volver al Inicio
                </a>

                <a href="tel:+5491150974821" class="w-full sm:w-auto bg-marca hover:bg-marca-hover text-white font-bold py-4 px-8 rounded-xl shadow-lg shadow-marca/20 transition-all flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 004.529 4.53l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-1C7.22 18 2 12.78 2 6V3z" />
                    </svg>
                    Llamar ahora
                </a>
            </div>

        </div>
    </section>
</Layout>