---

interface Props {
    region?: string;
}
const { region } = Astro.props;

//las reseñas reales de tu Google Mi Negocio
const resenas = [
    {
        nombre: "Martín G.",
        tiempo: "Hace 2 semanas",
        texto: "Se me trabó la puerta pentágono un domingo a la noche. En 20 minutos estaban en casa y la abrieron sin romper nada. Súper recomendables, te explican todo.",
        inicial: "M"
    },
    {
        nombre: "Laura S.",
        tiempo: "Hace 1 mes",
        texto: "Excelente atención. Vinieron rápido a cambiar la combinación de la cerradura de mi local porque perdí las llaves. Precio justo y muy profesionales.",
        inicial: "L"
    },
    {
        nombre: "Diego R.",
        tiempo: "Hace 2 meses",
        texto: "Perdí las llaves del auto adentro del mismo y me salvaron. En el momento y destrabaron la puerta. Cobran lo que corresponde, muy honestos.",
        inicial: "D"
    }
    ];
---

<section class="py-20 md:py-32 bg-fondo-base border-t border-borde">
    <div class="max-w-6xl mx-auto px-4">
        
        <div class="text-center mb-16 animate-fade-in-up">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
            Lo que dicen nuestros <span class="text-blue-500">clientes</span>
        </h2>
        <p class="text-slate-400 max-w-2xl mx-auto text-lg">
            Más de 500 vecinos {region ? `de ${region}` : 'de la zona'} ya confiaron en nuestro servicio de cerrajería. Su tranquilidad es nuestra mejor garantía.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        
        {resenas.map((resena) => (
            // Tarjeta Individual
            <div class="bg-fondo-card border border-borde p-6 md:p-8 rounded-2xl hover:-translate-y-1 transition-transform duration-300 shadow-lg shadow-marca/5 flex flex-col h-full">
            
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-marca text-white flex items-center justify-center font-bold text-lg">
                    {resena.inicial}
                </div>
                <div>
                    <h3 class="text-white font-bold text-sm md:text-base">{resena.nombre}</h3>
                    <p class="text-slate-300 text-xs">{resena.tiempo}</p>
                </div>
                </div>
                
                <div class="w-6 h-6 bg-white rounded-full flex items-center justify-center p-1">
                <svg viewBox="0 0 24 24" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                </div>
            </div>

            <div class="flex gap-1 mb-4 text-yellow-500">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>

            <p class="text-slate-300 text-sm md:text-base leading-relaxed italic flex-1">
                "{resena.texto}"
            </p>

            </div>
        ))}

        </div>
    </div>
</section>