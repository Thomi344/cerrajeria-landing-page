---
// ---- Pagina de diseño de la seccion Hero ----
import { Image } from "astro:assets";
import Button from "../components/button.astro";
import AutoHero from "../assets/images/AutoHero.webp";
import LlaveHero from "../assets/images/LLaveHero.webp";

interface Props {
    nombreZona?: string;
    region?: string;
    barrios?: string[]; // --- Array de textos ---
}

const { 
    nombreZona = "tu zona", 
    region = "AMBA",
    barrios = [] //  --- Array vacío por defecto por si estamos en la /Home ---
} = Astro.props;


// --- Si hay barrios, arma el texto. Si no (ej: en la Home), muestra un texto genérico. ---
const textoBarrios = barrios.length > 0 
    ? `Atención inmediata en ${barrios.join(', ')} y zonas cercanas.`
    : `Cobertura completa en Zona Sur, CABA, Zona Norte y alrededores.`;
    
const telefono = "+5491150974821"; 

// --- Definimos los enlaces directos para el carrusel ---
const imagenesFondo = [
    {src: AutoHero, alt: "Cerrajero de urgencia abriendo auto"},
    {src: LlaveHero, alt: "Cerrajero de urgencia con llave en mano"}
];
---

<section id="hero-carousel" class="relative bg-fondo-base text-white overflow-hidden z-0 min-h-[80vh] flex items-center justify-center">
    
    <div class="absolute inset-0 z-[-2]">
            {imagenesFondo.map((img, index) => (
                <Image 
                    src={img.src} 
                    alt={img.alt}
                    widths={[600, 900, 1500]}
                    sizes="(max-width: 600px) 600px, (max-width: 1200px) 900px, 1500px"
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                    class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 carousel-img ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                    {...({ fetchpriority: index === 0 ? "high" : "low" } as any)} 
                />
            ))}
    </div>

    <div class="absolute inset-0 z-[-1] bg-black/75 backdrop-blur-[1px]"></div>

        <div class="relative max-w-6xl mx-auto px-4 pt-8 pb-24 md:pt-32 md:pb-32 flex flex-col items-center text-center z-10">
            
            <span class="text-blue-400 font-semibold tracking-wider uppercase text-sm mb-4 animate-fade-in-up">
                Atención Inmediata 24/7
            </span>
            
            <h1 class="text-5xl md:text-7xl font-extrabold mb-6 animate-fade-in-up animate-delay-100 tracking-tighter leading-none">
                Cerrajería de Urgencia en <span class="text-blue-500">{nombreZona}</span>
            </h1>
            
            <p class="text-lg md:text-xl text-slate-100 max-w-3xl mb-10 animate-fade-in-up animate-delay-200 leading-relaxed">
                Servicio integral de cerrajería en <strong>{region}</strong>. {textoBarrios} 
                <br/> Especialistas en <strong>aperturas sin romper</strong>, cambio de combinaciones, 
                instalación de cerraduras de alta seguridad y reparación de sistemas digitales. 
                Seguridad para hogares, comercios y vehículos.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up animate-delay-300 w-full sm:w-auto">
                <Button href={`https://wa.me/${telefono}`} texto="Pedir Cerrajero Ya" >
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                </Button>
                
            </div>

    </div>
</section>

<script>
    // --- Buscamos todas las imágenes dentro de la sección del carrusel ---
    const images = document.querySelectorAll('#hero-carousel .carousel-img');
    let currentIndex = 0;
    
    // --- Función que realiza el cambio de imagen ---
    function changeImage() {
        // --- Ocultamos la imagen actual ---
        images[currentIndex].classList.remove('opacity-100');
        images[currentIndex].classList.add('opacity-0');

        // ---Calculamos el índice de la siguiente imagen ---
        currentIndex = (currentIndex + 1) % images.length;

        // --- Mostramos la nueva imagen ---
        images[currentIndex].classList.remove('opacity-0');
        images[currentIndex].classList.add('opacity-100');
    }

    // --- Si hay más de una imagen, activamos el bucle automático cada 5 segundos ---
    if (images.length > 1) {
        setInterval(changeImage, 5000); 
    }
</script>