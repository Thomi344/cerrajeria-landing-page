---
// ---- Pagina de diseño de la seccion Footer ----
// --- 1. Importamos la 'base de datos' (Archivo zonas.js) de zonas reales ---
import { zonas } from '../data/zonas.js';

// --- Números de contacto ---
const telefonoWhatsapp = "5491150974821"; 
const telefonoLlamada = "+5491150974821"; 

// --- 2. Lógica SEO : Creamos la lista de enlaces apuntando al SLUG exacto --- 
const ubicaciones: { nombre: string, url: string }[] = [];
    zonas.forEach(zona => {
    // --- Agregamos la zona principal (ej: Lomas de Zamora -> /cerrajero-zona-lomas-de-zamora)---
    ubicaciones.push({ nombre: zona.nombre, url: `/${zona.slug}` });
    
    // ---- Agregamos todos sus barrios apuntando al mismo slug de su zona padre ---
    if (zona.barrios && zona.barrios.length > 0) {
        zona.barrios.forEach(barrio => {
        // --- Evitamos duplicar si un barrio se llama igual que la zona principal ---
        if (barrio.toLowerCase() !== zona.nombre.toLowerCase()) {
            ubicaciones.push({ nombre: barrio, url: `/${zona.slug}` });
        }
        });
    }
});
