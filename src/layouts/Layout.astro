---
import Whatsapp from '../components/whatsapp.astro';


const { 
    title = "Cerrajería Wally 24hs | Urgencias en GBA y CABA | ¡Llamá ahora!",
    description = "Cerrajero a domicilio 24 horas. Apertura de puertas, autos y cajas fuertes. Rápidos, limpios y con garantía en el día."
} = Astro.props;

const dominioActual = "https://cerrajeriawally.com.ar";
const urlActual = "https://cerrajeriawally.com.ar";
const ogImage = `${dominioActual}/SocialShare-1.jpg`;

const businessSchema = {
    "@context": "https://schema.org",
    "@type": "Locksmith",
    "name": "Cerrajería Wally",
    "image": `${dominioActual}/logo-icon.webp`,
    "@id": dominioActual,
    "url": dominioActual,
    "telephone": "+5491150974821",
    "priceRange": "$$",
    "address": {
        "@type": "PostalAddress",
        "addressLocality": "Buenos Aires",
        "addressCountry": "AR"
    },
    "geo": {
        "@type": "GeoCircle",
        "itemOffered": {
        "@type": "Service",
        "name": "Cerrajería de Urgencia 24hs"
        },
        "address": "Zona Sur, CABA y alrededores" 
    },
    "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
        "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
        ],
        "opens": "00:00",
        "closes": "23:59"
    }
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <script is:inline>window.dataLayer = window.dataLayer || [];</script>

        <script type="text/plain" id="gtm-script">
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-5MVVGKX5');
        </script>

        <script is:inline>
            const initGTM = () => {
                if (window._gtmLoaded) return;
                window._gtmLoaded = true;
                if (/bot|googlebot|crawler|spider|robot|crawling|lighthouse/i.test(navigator.userAgent)) return;
                
                // Buscamos el script dormido y lo convertimos a Partytown
                const gtmScript = document.getElementById('gtm-script');
                if (gtmScript) {
                    const newScript = document.createElement('script');
                    newScript.type = 'text/partytown';
                    newScript.innerHTML = gtmScript.innerHTML;
                    document.head.appendChild(newScript);
                    
                    // Le damos el empujoncito final para que corra
                    window.dispatchEvent(new CustomEvent('pt:run'));
                }
            };

            // Escuchamos movimientos reales (el bot de Google no hace esto)
            ['mousemove', 'touchstart', 'scroll', 'keydown', 'click'].forEach(evt => {
                window.addEventListener(evt, initGTM, { once: true });
            });
        </script>

        <link rel="icon" type="image/webp" href="/logo-icon.webp" />
        
		<link rel="preconnect" href="https://res.cloudinary.com" />      

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={urlActual} />
        <meta name="robots" content="index, follow" />

		<meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={urlActual} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Cerrajería Wally" />
        <meta property="og:locale" content="es_AR" />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={urlActual} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImage} />
        <meta name="google-site-verification" content="_olVUSz4V6CrwUiX6bEOeQ_nBeEOO6GtPS-OKi5hkXQ" />
        
        <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
    </head>
    <body class="bg-fondo-base text-slate-200 selection:bg-blue-500/30">
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5MVVGKX5"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <slot /> 
        <Whatsapp />
    </body>
</html>

<style is:global>
    /* Optimizamos la carga de Tailwind */
    @import 'tailwindcss';
    @import 'tailwind-animations';

    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100vh;
        /* Suavizamos el renderizado de fuentes para mejorar el Speed Index */
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
    }

    /* Aseguramos que el carrusel no bloquee el scroll horizontal */
    #carrusel-trabajos {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    @theme {
        --color-marca: #2563eb; 
        --color-marca-hover: #1d4ed8; 
        --color-marca-suave: #3b82f6; 
        --color-wpp: #22c55e; 
        --color-wpp-hover: #16a34a; 
        --color-fondo-base: #0f172a; 
        --color-fondo-nav: #020617;  
        --color-fondo-card: #1e293b; 
        --color-borde: #334155;      
    }
</style>